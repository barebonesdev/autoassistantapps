<local:MainScreenContentViewHostGeneric
    x:Name="thisPage"
    x:Class="AutoAssistantUWP.Views.OverviewView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AutoAssistantUWP.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <ScrollViewer>
            <Grid>
                <StackPanel MaxWidth="500" Margin="24" HorizontalAlignment="Stretch">
                    <Grid HorizontalAlignment="Left">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Text="{Binding Vehicle.Nickname}"
                            Style="{ThemeResource SubtitleTextBlockStyle}"
                            IsTextSelectionEnabled="True"
                            VerticalAlignment="Center"
                            Margin="0,-2,6,0"/>
                        <Button
                            x:Name="ButtonEdit"
                            Grid.Column="1"
                            Style="{ThemeResource HeaderButtonStyle}"
                            Click="ButtonEdit_Click">
                            <SymbolIcon Symbol="Edit"/>
                        </Button>
                        <Button
                            x:Name="ButtonDelete"
                            Grid.Column="2"
                            Style="{ThemeResource HeaderButtonStyle}"
                            Click="ButtonDelete_Click">
                            <SymbolIcon Symbol="Delete"/>
                        </Button>
                    </Grid>
                    <TextBlock
                        Text="{Binding Vehicle.YearMakeModelString}"
                        Style="{ThemeResource BodyTextBlockStyle}"
                        Margin="0,12,0,0"
                        IsTextSelectionEnabled="True"/>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Text="Initial mileage:"
                            Style="{ThemeResource BaseTextBlockStyle}"
                            Margin="0,0,6,0"/>
                        <TextBlock
                            Grid.Column="1"
                            Text="{Binding Vehicle.InitialMileage}"
                            Style="{ThemeResource BodyTextBlockStyle}"
                            IsTextSelectionEnabled="True"/>

                        <TextBlock
                            Grid.Row="1"
                            Text="Purchased for:"
                            Style="{ThemeResource BaseTextBlockStyle}"
                            Margin="0,0,6,0"/>
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="1"
                            Text="{Binding Vehicle.AmountPurchasedFor}"
                            Style="{ThemeResource BodyTextBlockStyle}"
                            IsTextSelectionEnabled="True"/>

                        <TextBlock
                            Grid.Row="2"
                            Text="Purchased from:"
                            Style="{ThemeResource BaseTextBlockStyle}"
                            Margin="0,0,6,0"/>
                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="1"
                            Text="{Binding Vehicle.PurchasedFrom}"
                            Style="{ThemeResource BodyTextBlockStyle}"
                            IsTextSelectionEnabled="True"/>

                        <TextBlock
                            Grid.Row="3"
                            Text="License plate:"
                            Style="{ThemeResource BaseTextBlockStyle}"
                            Margin="0,0,6,0"/>
                        <TextBlock
                            Grid.Row="3"
                            Grid.Column="1"
                            Text="{Binding Vehicle.LicensePlate}"
                            Style="{ThemeResource BodyTextBlockStyle}"
                            IsTextSelectionEnabled="True"/>

                        <TextBlock
                            Grid.Row="4"
                            Text="VIN:"
                            Style="{ThemeResource BaseTextBlockStyle}"
                            Margin="0,0,6,0"/>
                        <TextBlock
                            Grid.Row="4"
                            Grid.Column="1"
                            Text="{Binding Vehicle.VIN}"
                            Style="{ThemeResource BodyTextBlockStyle}"
                            IsTextSelectionEnabled="True"/>

                    </Grid>

                    <TextBlock
                        Text="{Binding Vehicle.Notes}"
                        TextWrapping="Wrap"
                        Margin="0,12,0,0"
                        Style="{ThemeResource BodyTextBlockStyle}"
                        IsTextSelectionEnabled="True"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</local:MainScreenContentViewHostGeneric>
