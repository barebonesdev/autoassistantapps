<interfacesViews:ViewHostGeneric
    x:Name="ThisView"
    xmlns:interfacesViews="using:InterfacesUWP.Views"
    x:Class="AutoAssistantUWP.Views.MainScreenView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AutoAssistantUWP.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:interfacesViewPresenters="using:InterfacesUWP.ViewModelPresenters"
    xmlns:localConverters="using:AutoAssistantUWP.Converters"
    mc:Ignorable="d"
    SizeChanged="ThisView_SizeChanged">

    <interfacesViews:ViewHostGeneric.Resources>
        <Style x:Key="GlyphIconStyle" TargetType="FontIcon">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
        </Style>
        <localConverters:MainMenuSelectionToMainMenuItemConverter x:Key="MainMenuSelectionToMainMenuItemConverter"/>
        <localConverters:SyncStateToStringConverter x:Key="SyncStateToStringConverter"/>
        <localConverters:MilesToStringConverter x:Key="MilesToStringConverter"/>
        <Storyboard x:Name="StoryboardSyncing">
            <DoubleAnimation To="360" From="0" RepeatBehavior="Forever" Duration="0:0:2.5" Storyboard.TargetName="SyncIconTransform" Storyboard.TargetProperty="Angle"/>
        </Storyboard>
    </interfacesViews:ViewHostGeneric.Resources>

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.ChildrenTransitions>
            <TransitionCollection>
                <EntranceThemeTransition />
            </TransitionCollection>
        </Grid.ChildrenTransitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!--Top title bar-->
        <Grid Background="{ThemeResource AutoAssistantTitleBarBackgroundBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="48"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button
                x:Name="ButtonMenu"
                Style="{StaticResource TransparentButtonStyle}"
                Foreground="{ThemeResource AutoAssistantTitleBarForegroundBrush}"
                Click="ButtonMenu_Click"
                VerticalAlignment="Stretch"
                HorizontalAlignment="Stretch"
                Padding="0">
                <FontIcon
                    Glyph="&#xE700;"
                    Style="{StaticResource GlyphIconStyle}"
                    Margin="12,8,8,8"
                    VerticalAlignment="Center"/>
            </Button>

            <TextBlock
                Grid.Column="1"
                Text="{Binding SelectedItem}"
                Style="{ThemeResource TitleTextBlockStyle}"
                Margin="12,0,12,0"
                VerticalAlignment="Center"/>

            <StackPanel
                Grid.Column="2"
                VerticalAlignment="Center"
                HorizontalAlignment="Right"
                Margin="0,0,12,0">
                <TextBlock
                    Text="{Binding CurrentVehicle.Nickname}"
                    Style="{ThemeResource BodyTextBlockStyle}"
                    MaxLines="1"
                    FontWeight="SemiBold"
                    TextAlignment="Right"/>
                <TextBlock
                    Text="{Binding CurrentVehicle.EstimatedMileage, Converter={StaticResource MilesToStringConverter}}"
                    Style="{ThemeResource CaptionTextBlockStyle}"
                    TextAlignment="Right"/>
            </StackPanel>
        </Grid>
        
        <!--Content section-->
        <SplitView
            x:Name="SplitViewMenu"
            Grid.Row="1"
            DisplayMode="CompactInline"
            OpenPaneLength="230">
            <SplitView.Pane>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!--Main menu items-->
                    <ListView
                        x:Name="ListViewMainMenuItems"
                        IsItemClickEnabled="True"
                        ItemClick="ListViewMainMenuItems_ItemClick"
                        ItemsSource="{Binding AvailableItems}">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Height="48" DataContext="{Binding Converter={StaticResource MainMenuSelectionToMainMenuItemConverter}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="36"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <FontIcon
                                        Glyph="{Binding Glyph}"
                                        Style="{StaticResource GlyphIconStyle}"
                                        Margin="0,8,8,8"/>
                                    <TextBlock
                                        Grid.Column="1"
                                        Text="{Binding Title}"
                                        Style="{ThemeResource BodyTextBlockStyle}"
                                        TextWrapping="NoWrap"
                                        VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <StackPanel Grid.Row="1">

                        <Button
                            x:Name="ButtonSyncErrors"
                            Style="{StaticResource TransparentButtonStyle}"
                            HorizontalAlignment="Stretch"
                            Height="48"
                            HorizontalContentAlignment="Left"
                            Click="ButtonSyncErrors_Click"
                            Visibility="{Binding HasSyncErrors, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid x:Name="ListViewBottomMenuItemSyncErrors">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <SymbolIcon
                                        Symbol="Important"
                                        Margin="-4,0,0,0"/>
                                <TextBlock
                                        Grid.Column="1"
                                        Text="View sync errors"
                                        Style="{ThemeResource BodyTextBlockStyle}"
                                        TextWrapping="NoWrap"
                                        VerticalAlignment="Center"/>
                            </Grid>
                        </Button>

                        <Button
                            x:Name="ButtonSync"
                            Style="{StaticResource TransparentButtonStyle}"
                            HorizontalAlignment="Stretch"
                            Height="48"
                            HorizontalContentAlignment="Left"
                            Click="ButtonSync_Click">
                            <Grid x:Name="ListViewBottomMenuItemSync">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <SymbolIcon
                                    x:Name="SyncIcon"
                                    Symbol="Sync"
                                    RenderTransformOrigin="0.5,0.5"
                                    Margin="-4,0,0,0"
                                    Visibility="{Binding IsOffline, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Negate}">
                                    <SymbolIcon.RenderTransform>
                                        <RotateTransform
                                            x:Name="SyncIconTransform"/>
                                    </SymbolIcon.RenderTransform>
                                </SymbolIcon>
                                <TextBlock
                                    Grid.Column="1"
                                    Text="{Binding SyncState, Converter={StaticResource SyncStateToStringConverter}}"
                                    Style="{ThemeResource BodyTextBlockStyle}"
                                    TextWrapping="NoWrap"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding IsOffline, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Negate}"/>
                                <SymbolIcon
                                    Symbol="DisableUpdates"
                                    Margin="-8,0,0,0"
                                    Visibility="{Binding IsOffline, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                <TextBlock
                                    Grid.Column="1"
                                    Text="Offline, try syncing again"
                                    Style="{ThemeResource BodyTextBlockStyle}"
                                    TextWrapping="NoWrap"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding IsOffline, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </Grid>
                        </Button>

                        <Button
                            x:Name="ButtonSettings"
                            Style="{StaticResource TransparentButtonStyle}"
                            HorizontalAlignment="Stretch"
                            Height="48"
                            HorizontalContentAlignment="Left"
                            Click="ButtonSettings_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <SymbolIcon
                                        Symbol="Setting"
                                        Margin="-4,0,0,0"/>
                                <TextBlock
                                        Grid.Column="1"
                                        Text="Settings"
                                        Style="{ThemeResource BodyTextBlockStyle}"
                                        TextWrapping="NoWrap"
                                        VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                    </StackPanel>
                </Grid>
            </SplitView.Pane>

            <!--Main content-->
            <interfacesViewPresenters:PagedViewModelPresenter
                x:Name="ContentPresenter"
                Grid.Row="1"
                Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                ViewModel="{Binding}"/>
        </SplitView>

        <!--Popups-->
        <interfacesViewPresenters:PopupsPresenter
                Grid.RowSpan="2"
                Grid.ColumnSpan="2"
                ViewModel="{Binding}"
                RequestedTheme="Default"/>
        
    </Grid>
</interfacesViews:ViewHostGeneric>
