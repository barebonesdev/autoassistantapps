<local:MainScreenContentViewHostGeneric
    x:Name="thisPage"
    x:Class="AutoAssistantUWP.Views.GarageView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AutoAssistantUWP.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    xmlns:views="using:AutoAssistantUWP.Views">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <GridView
            ItemsSource="{Binding Vehicles}"
            IsItemClickEnabled="True"
            ItemClick="ListViewVehicles_ItemClick"
            Padding="12">
            <GridView.ItemTemplate>
                <DataTemplate>
                    <views:GarageVehicleView />
                </DataTemplate>
            </GridView.ItemTemplate>
            <GridView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsWrapGrid MaximumRowsOrColumns="3" Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </GridView.ItemsPanel>
            <GridView.Footer>
                <Button Content="Add Vehicle" Style="{ThemeResource AddItemButtonStyle}" Margin="12" Click="ButtonAddVehicle_Click"/>
            </GridView.Footer>
        </GridView>
    </Grid>
</local:MainScreenContentViewHostGeneric>
