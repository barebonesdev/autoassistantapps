<local:PopupViewHostGeneric
    x:Name="ThisPage"
    x:Class="AutoAssistantUWP.Views.AddFuelView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AutoAssistantUWP.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    xmlns:converters="using:AutoAssistantUWP.Converters">

    <local:PopupViewHostGeneric.Resources>

        <converters:MpgToStringConverter x:Key="MpgToStringConverter"/>

    </local:PopupViewHostGeneric.Resources>

    <local:PopupViewHostGeneric.PrimaryCommands>

        <AppBarButton
            x:Uid="AppBarButtonSave"
            x:Name="ButtonSave"
            Icon="Save"
            Label="Save"
            Click="ButtonSave_Click"/>

    </local:PopupViewHostGeneric.PrimaryCommands>

    <local:PopupViewHostGeneric.MainContent>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="12">
                <StackPanel.Resources>
                    <Style TargetType="TextBox">
                        <Setter Property="IsSpellCheckEnabled" Value="True"/>
                        <Setter Property="IsTextPredictionEnabled" Value="True"/>
                    </Style>
                </StackPanel.Resources>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBox
                        x:Name="tbOdometer"
                        Header="Odometer"
                        Loaded="tbOdometer_Loaded"
                        InputScope="Number"
                        PlaceholderText="ex: 87439"
                        Margin="0,0,6,0"
                        Text="{Binding Mileage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DecimalToTextBoxTextConverter}}"
                        KeyUp="tbOdometer_KeyUp"/>

                    <TextBox
                        x:Name="tbGallons"
                        Grid.Column="1"
                        Header="Gallons"
                        Loaded="tbOdometer_Loaded"
                        InputScope="Number"
                        PlaceholderText="ex: 13.251"
                        Margin="6,0,0,0"
                        Text="{Binding Gallons, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DecimalToTextBoxTextConverter}}"
                        KeyUp="tbGallons_KeyUp"/>
                </Grid>

                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBox
                        x:Name="tbTotalCost"
                        Header="Total cost"
                        InputScope="CurrencyAmount"
                        PlaceholderText="ex: 34.21"
                        Margin="0,0,6,0"
                        Text="{Binding TotalCost, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DecimalToTextBoxTextConverter}}"
                        KeyUp="tbTotalCost_KeyUp"/>

                    <TextBlock
                        Text="{Binding MPG, Converter={StaticResource MpgToStringConverter}}"
                        Grid.Column="1"
                        Margin="10,0,0,0"
                        Style="{ThemeResource TitleTextBlockStyle}"
                        Foreground="{ThemeResource SystemControlHighlightAccentBrush}"
                        VerticalAlignment="Bottom"
                        TextWrapping="NoWrap"/>
                </Grid>

                <CalendarDatePicker
                    x:Name="DatePickerDate"
                    Margin="0,12,0,0"
                    Header="Date"
                    HorizontalAlignment="Stretch"
                    Date="{Binding Date, Mode=TwoWay, Converter={StaticResource DateTimeToDateTimeOffsetConverter}}"/>

                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="6*"/>
                        <ColumnDefinition Width="4*"/>
                    </Grid.ColumnDefinitions>

                    <TextBox
                        Header="Store name"
                        InputScope="NameOrPhoneNumber"
                        PlaceholderText="QuikTrip"
                        Margin="0,0,6,0"
                        Text="{Binding StoreName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                    <ComboBox
                        x:Name="ComboBoxFuelTypes"
                        Grid.Column="1"
                        HorizontalAlignment="Stretch"
                        Margin="6,0,0,0"
                        Header="Fuel type"
                        ItemsSource="{Binding AvailableFuelTypes, Mode=OneTime}"
                        SelectedItem="{Binding FuelType, Mode=TwoWay}"/>
                </Grid>

                <CheckBox
                    IsChecked="{Binding PartialFill, Mode=TwoWay}"
                    Margin="0,12,0,0"
                    Content="Partial fillup (did not fill 100% full)"/>

                <CheckBox
                    IsChecked="{Binding SkippedEnteringPreviousFillup, Mode=TwoWay}"
                    Margin="0,12,0,0"
                    Content="Skipped entering previous fillup"/>

                <TextBox
                    x:Name="tbNotes"
                    Header="Notes"
                    Text="{Binding Notes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    AcceptsReturn="True"
                    TextWrapping="Wrap"
                    IsTextPredictionEnabled="True"
                    IsSpellCheckEnabled="True"
                    InputScope="Text"
                    Margin="0,12,0,0"/>

            </StackPanel>
        </ScrollViewer>

    </local:PopupViewHostGeneric.MainContent>
</local:PopupViewHostGeneric>
