<local:PopupViewHostGeneric
    x:Class="AutoAssistantUWP.Views.ViewFuelView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AutoAssistantUWP.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="VIEW FUEL">

    <local:PopupViewHostGeneric.PrimaryCommands>

        <AppBarButton
            x:Uid="AppBarButtonEdit"
            x:Name="ButtonEdit"
            Icon="Edit"
            Label="Edit"
            Click="ButtonEdit_Click"/>

        <AppBarButton
            x:Uid="AppBarButtonDelete"
            x:Name="ButtonDelete"
            Icon="Delete"
            Label="Delete"
            Click="ButtonDelete_Click"/>

    </local:PopupViewHostGeneric.PrimaryCommands>

    <local:PopupViewHostGeneric.MainContent>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
            <StackPanel>
                
                <!--Grids of data-->
                <StackPanel>

                    <Grid VerticalAlignment="Top">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="1"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" Margin="2,0,6,18" HorizontalAlignment="Right">
                            <TextBlock
                                Text="{Binding MpgString}"
                                Style="{ThemeResource HeaderTextBlockStyle}"
                                TextWrapping="NoWrap"
                                Foreground="{ThemeResource SystemControlHighlightAccentBrush}"
                                TextLineBounds="Tight"
                                VerticalAlignment="Bottom"/>
                            <TextBlock
                                Text="mpg"
                                Style="{ThemeResource SubheaderTextBlockStyle}"
                                TextWrapping="NoWrap"
                                Opacity="0.6"
                                TextLineBounds="Tight"
                                VerticalAlignment="Bottom"
                                Margin="6,0,0,0"/>
                        </StackPanel>

                        <!--Vertical divider-->
                        <Rectangle
                            Grid.Column="1"
                            Grid.RowSpan="3"
                            Fill="{ThemeResource SystemControlHighlightAccentBrush}"/>

                        <StackPanel Grid.Column="2">
                            <TextBlock
                                Text="{Binding MilesString}"
                                Style="{ThemeResource BodyTextBlockStyle}"
                                TextWrapping="NoWrap"
                                Margin="6,6,0,6"/>

                            <!--Horizontal divider-->
                            <Rectangle
                                Fill="{ThemeResource SystemControlHighlightAccentBrush}"
                                Height="1"/>

                            <TextBlock
                                Text="{Binding TotalMilesString}"
                                Style="{ThemeResource BodyTextBlockStyle}"
                                TextWrapping="NoWrap"
                                Margin="6,6,0,6"/>
                        </StackPanel>
                    </Grid>

                    <!--Horizontal divider-->
                    <Rectangle
                        Fill="{ThemeResource SystemControlHighlightAccentBrush}"
                        Height="1"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="1"/>
                            <ColumnDefinition Width="6*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock
                                Text="{Binding GallonsString}"
                                Style="{ThemeResource BodyTextBlockStyle}"
                                TextWrapping="NoWrap"
                                Margin="3,6,6,6"/>

                            <!--Horizontal divider-->
                            <Rectangle
                                Grid.Row="1"
                                Fill="{ThemeResource SystemControlHighlightAccentBrush}"
                                Height="1"/>

                            <TextBlock
                                Grid.Row="2"
                                Text="{Binding CostPerGallonString}"
                                Style="{ThemeResource BodyTextBlockStyle}"
                                TextWrapping="NoWrap"
                                Margin="3,6,6,6"/>
                        </StackPanel>

                        <!--Vertical divider-->
                        <Rectangle
                            Grid.Column="1"
                            Grid.RowSpan="3"
                            Fill="{ThemeResource SystemControlHighlightAccentBrush}"/>

                        <TextBlock
                            Grid.Column="2"
                            Text="{Binding TotalCostString}"
                            Style="{ThemeResource HeaderTextBlockStyle}"
                            TextWrapping="NoWrap"
                            Opacity="0.6"
                            TextLineBounds="Tight"
                            Margin="15,0,0,0"
                            VerticalAlignment="Center"/>
                    </Grid>

                </StackPanel>
            </StackPanel>
        </ScrollViewer>

    </local:PopupViewHostGeneric.MainContent>
</local:PopupViewHostGeneric>
