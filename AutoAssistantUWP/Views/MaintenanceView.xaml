<local:MainScreenContentViewHostGeneric
    x:Class="AutoAssistantUWP.Views.MaintenanceView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AutoAssistantUWP.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <local:MainScreenContentViewHostGeneric.Resources>
        <DataTemplate x:Key="UpcomingServiceItemTemplate">
            <Grid Margin="0,2,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <!--Hidden one to reserve proper amount of space-->
                <TextBlock
                        Text="2,222"
                        Style="{ThemeResource SubtitleTextBlockStyle}"
                        Opacity="0"
                        MaxLines="1"
                        HorizontalAlignment="Center"/>
                <StackPanel>
                    <TextBlock
                        Text="{Binding Counter}"
                        Style="{ThemeResource SubtitleTextBlockStyle}"
                        Foreground="{ThemeResource SystemControlHighlightAccentBrush}"
                        MaxLines="1"
                        HorizontalAlignment="Center"/>
                    <TextBlock
                        Text="{Binding CounterType}"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        Opacity="0.6"
                        MaxLines="1"
                        HorizontalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="6,0,0,0">
                    <TextBlock
                        Text="{Binding ScheduleItem.Title}"
                        Style="{ThemeResource SubtitleTextBlockStyle}"
                        TextTrimming="CharacterEllipsis"
                        MaxLines="1"/>
                    <TextBlock
                        Text="{Binding Subtitle}"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource SystemControlHighlightAccentBrush}"
                        TextTrimming="Clip"
                        MaxLines="1"/>
                </StackPanel>
            </Grid>
        </DataTemplate>
    </local:MainScreenContentViewHostGeneric.Resources>

    <Grid x:Name="RootGrid" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" SizeChanged="RootGrid_SizeChanged">
        <Grid x:Name="GridFullSize" MaxWidth="700">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!--Upcoming/overdue services-->
            <ListView
                x:Name="ListViewUpcomingServices"
                ItemsSource="{Binding FutureServices}"
                Grid.RowSpan="3"
                IsItemClickEnabled="True"
                SelectionMode="None"
                ItemClick="ListViewUpcomingServices_ItemClick"
                ItemTemplate="{StaticResource UpcomingServiceItemTemplate}"
                Padding="0,0,0,12">
                <ListView.Header>
                    <StackPanel>
                        <!--Overdue section-->
                        <StackPanel Margin="0,20,0,0" Visibility="{Binding HasOverdueServices, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock
                                Text="Overdue"
                                Style="{ThemeResource SubtitleTextBlockStyle}"
                                Foreground="{ThemeResource SystemControlHighlightAccentBrush}"
                                FontWeight="SemiBold"
                                Margin="12,0,0,0"/>
                            <ListView
                                ItemsSource="{Binding OverdueServices}"
                                IsItemClickEnabled="True"
                                ItemClick="ListViewUpcomingServices_ItemClick"
                                SelectionMode="None"
                                ItemTemplate="{StaticResource UpcomingServiceItemTemplate}"/>
                        </StackPanel>

                        <!--Next service-->
                        <StackPanel Margin="0,20,0,0" Visibility="{Binding HasNextServices, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock
                                Text="Next service"
                                Style="{ThemeResource SubtitleTextBlockStyle}"
                                Opacity="0.6"
                                FontWeight="SemiBold"
                                TextWrapping="NoWrap"
                                Margin="12,0,0,0"/>
                            <ListView
                                ItemsSource="{Binding NextServices}"
                                IsItemClickEnabled="True"
                                ItemClick="ListViewUpcomingServices_ItemClick"
                                SelectionMode="None"
                                ItemTemplate="{StaticResource UpcomingServiceItemTemplate}"/>
                        </StackPanel>

                        <!--Nothing-->
                        <TextBlock
                            Text="Add some items to your schedule!"
                            Style="{ThemeResource SubtitleTextBlockStyle}"
                            Opacity="0.6"
                            FontWeight="SemiBold"
                            Margin="12,20,0,0"
                            Visibility="{Binding HasNoServices, Converter={StaticResource BoolToVisibilityConverter}}"/>

                        <TextBlock
                            Text="Future services"
                            Style="{ThemeResource SubtitleTextBlockStyle}"
                            Opacity="0.6"
                            FontWeight="SemiBold"
                            TextWrapping="NoWrap"
                            Margin="12,20,0,0"
                            Visibility="{Binding HasFutureServices, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </StackPanel>
                </ListView.Header>
            </ListView>

            <Rectangle
                Grid.Column="1"
                Grid.RowSpan="3"
                Fill="Gray"
                Width="1"
                Margin="0,20"/>

            <!--Records-->
            <Grid
                x:Name="GridFullSizeRecords"
                Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Margin="12,12,12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Text="Records"
                        Style="{ThemeResource TitleTextBlockStyle}"
                        Margin="0,2,3,0"/>
                    <Button
                        x:Name="ButtonSearchRecords"
                        Grid.Column="1"
                        Style="{StaticResource HeaderButtonStyle}"
                        Click="ButtonSearchRecords_Click">
                        <SymbolIcon Symbol="Find"/>
                    </Button>
                    <Button
                        x:Name="ButtonAddRecord"
                        Grid.Column="2"
                        Style="{StaticResource HeaderButtonStyle}"
                        Click="ButtonAddRecord_Click">
                        <SymbolIcon Symbol="Add"/>
                    </Button>
                </Grid>
                <ListView
                    Grid.Row="1"
                    x:Name="ListViewRecords"
                    ItemsSource="{Binding MaintenanceRecords}"
                    IsItemClickEnabled="True"
                    ItemClick="ListViewRecords_ItemClick"
                    SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,2,0,8">
                                <TextBlock
                                    Text="{Binding Title}"
                                    Style="{ThemeResource SubtitleTextBlockStyle}"
                                    TextWrapping="NoWrap"
                                    MaxLines="1"/>

                                <TextBlock
                                    Text="{Binding Subtitle}"
                                    Style="{ThemeResource CaptionTextBlockStyle}"
                                    TextWrapping="NoWrap"
                                    MaxLines="1"
                                    Foreground="{ThemeResource SystemControlHighlightAccentBrush}"/>

                                <TextBlock
                                    Text="{Binding SecondarySubtitle}"
                                    Style="{ThemeResource CaptionTextBlockStyle}"
                                    TextWrapping="NoWrap"
                                    MaxLines="1"
                                    Opacity="0.6"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <Rectangle
                Grid.Column="2"
                Grid.Row="1"
                Height="1"
                Fill="Gray"
                Margin="12,0"/>

            <Grid
                x:Name="GridFullSizeSchedule"
                Grid.Column="2"
                Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Margin="12,12,12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Text="Schedule"
                        Style="{ThemeResource TitleTextBlockStyle}"
                        Margin="0,2,3,0"/>
                    <Button
                        x:Name="ButtonAddScheduleItem"
                        Grid.Column="1"
                        Style="{StaticResource HeaderButtonStyle}"
                        Click="ButtonAddScheduleItem_Click">
                        <SymbolIcon Symbol="Add"/>
                    </Button>
                </Grid>
                <ListView
                    Grid.Row="1"
                    x:Name="ListViewSchedule"
                    ItemsSource="{Binding ScheduleItems}"
                    IsItemClickEnabled="True"
                    ItemClick="ListViewSchedule_ItemClick"
                    SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,2,0,8">
                                <TextBlock
                                    Text="{Binding Title}"
                                    Style="{ThemeResource SubtitleTextBlockStyle}"
                                    TextWrapping="NoWrap"
                                    MaxLines="1"/>

                                <TextBlock
                                    Text="{Binding Subtitle}"
                                    Style="{ThemeResource CaptionTextBlockStyle}"
                                    TextWrapping="NoWrap"
                                    MaxLines="1"
                                    Foreground="{ThemeResource SystemControlHighlightAccentBrush}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

        </Grid>

        <Grid x:Name="GridCompact" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Pivot x:Name="PivotCompact" SelectionChanged="PivotCompact_SelectionChanged">
                <PivotItem x:Name="PivotItemUpcoming" Header="Upcoming"/>
                <PivotItem x:Name="PivotItemRecords" Header="Records"/>
                <PivotItem x:Name="PivotItemSchedule" Header="Schedule"/>
            </Pivot>
            <CommandBar
                Grid.Row="1">
                <CommandBar.PrimaryCommands>
                    <AppBarButton
                        x:Name="AppBarButtonAdd"
                        Click="AppBarButtonAdd_Click"
                        Icon="Add"
                        Label="Add record"/>
                    <AppBarButton
                        x:Name="AppBarButtonSearch"
                        Click="AppBarButtonSearch_Click"
                        Icon="Find"
                        Label="Search records"
                        Visibility="Collapsed"/>
                </CommandBar.PrimaryCommands>
            </CommandBar>
        </Grid>

        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup>
                <VisualState x:Name="FullSize"/>
                <VisualState x:Name="Compact">
                    <VisualState.Setters>
                        <Setter Target="GridFullSize.Visibility" Value="Collapsed"/>
                        <Setter Target="GridCompact.Visibility" Value="Visible"/>

                        <Setter Target="ListViewUpcomingServices.Margin" Value="-12,0"/>
                        <Setter Target="ListViewRecords.Margin" Value="-12,0"/>
                        <Setter Target="ListViewSchedule.Margin" Value="-12,0"/>
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
    </Grid>
</local:MainScreenContentViewHostGeneric>
