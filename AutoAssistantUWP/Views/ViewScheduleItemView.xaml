<local:PopupViewHostGeneric
    x:Class="AutoAssistantUWP.Views.ViewScheduleItemView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AutoAssistantUWP.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="VIEW SCHEDULE ITEM">

    <local:PopupViewHostGeneric.PrimaryCommands>

        <AppBarButton
            x:Uid="AppBarButtonEdit"
            x:Name="ButtonEdit"
            Icon="Edit"
            Label="Edit"
            Click="ButtonEdit_Click"/>

        <AppBarButton
            x:Uid="AppBarButtonDelete"
            x:Name="ButtonDelete"
            Icon="Delete"
            Label="Delete"
            Click="ButtonDelete_Click"/>

    </local:PopupViewHostGeneric.PrimaryCommands>

    <local:PopupViewHostGeneric.MainContent>

        <ListView
            x:Name="ListViewRecords"
            ItemsSource="{Binding Records}"
            IsItemClickEnabled="True"
            ItemClick="ListViewRecords_ItemClick" Padding="0,0,0,12">
            <ListView.Header>
                <StackPanel Margin="12,10,12,6">
                    <TextBlock
                        Text="{Binding ScheduleItem.Title}"
                        Style="{ThemeResource TitleTextBlockStyle}"
                        TextWrapping="Wrap"/>
                    <TextBlock
                        Text="{Binding ScheduleItem.Subtitle}"
                        Style="{ThemeResource BodyTextBlockStyle}"
                        TextWrapping="Wrap"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource SystemControlHighlightAccentBrush}"/>

                    <TextBlock
                        Text="{Binding ScheduleItem.Details}"
                        Style="{ThemeResource BodyTextBlockStyle}"
                        TextWrapping="Wrap"
                        Margin="0,12,0,0"
                        Visibility="{Binding ScheduleItem.Details, Converter={StaticResource StringToVisibilityConverter}}"/>

                    <TextBlock
                        Text="Records"
                        Opacity="0.6"
                        Style="{ThemeResource TitleTextBlockStyle}"
                        Margin="0,24,0,0"/>
                </StackPanel>
            </ListView.Header>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="0,2,0,8">
                        <TextBlock
                            Text="{Binding Title}"
                            Style="{ThemeResource SubtitleTextBlockStyle}"
                            TextWrapping="NoWrap"
                            MaxLines="1"/>
                        <TextBlock
                            Text="{Binding Subtitle}"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Opacity="0.6"
                            TextWrapping="NoWrap"
                            MaxLines="1"/>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

    </local:PopupViewHostGeneric.MainContent>
</local:PopupViewHostGeneric>
