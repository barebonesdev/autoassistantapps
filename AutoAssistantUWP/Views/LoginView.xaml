<views:PopupViewHostGeneric
    x:Uid="LoginPage"
    xmlns:views="using:AutoAssistantUWP.Views"
    x:Name="thisPage"
    x:Class="AutoAssistantUWP.Views.LoginView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AutoAssistantUWP.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="LOG IN">

    <views:PopupViewHostGeneric.MainContent>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Margin="20">

                    <AutoSuggestBox
                    x:Uid="LoginPage_TextBoxUsername"
                    x:Name="tbUsername"
                    Header="Username"
                    KeyUp="tbUsername_KeyUp"
                    ItemsSource="{Binding AccountsWithRememberUsername}"
                    DisplayMemberPath="Username" TextMemberPath="Username"
                    Loaded="tbUsername_Loaded"
                        Text="{Binding Username, Mode=TwoWay}"
                        TabIndex="0">

                        <AutoSuggestBox.TextBoxStyle>
                            <Style TargetType="TextBox">
                                <Setter Property="InputScope" Value="Default"/>
                                <Setter Property="IsTextPredictionEnabled" Value="False"/>
                                <Setter Property="IsSpellCheckEnabled" Value="False"/>
                            </Style>
                        </AutoSuggestBox.TextBoxStyle>

                    </AutoSuggestBox>

                    <PasswordBox
                    x:Uid="LoginPage_TextBoxPassword"
                    x:Name="tbPassword"
                    Header="Password"
                    Margin="0,12,0,0"
                    KeyUp="tbPassword_KeyUp"
                        Password="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        TabIndex="1"/>

                    <StackPanel
                    Margin="0,20,0,10"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">

                        <Button
                            Style="{StaticResource TransparentButtonStyle}"
                            x:Name="ButtonForgotUsername"
                            Click="ButtonForgotUsername_Click"
                            TabIndex="3">
                            <TextBlock
                                x:Uid="LoginPage_TextBlockForgotUsername"
                                Text="Forgot Username"
                                FontSize="14"/>
                        </Button>

                        <Rectangle
                            Width="1"
                            Fill="{ThemeResource ApplicationForegroundThemeBrush}"
                            Margin="0,3"/>

                        <Button
                            Style="{StaticResource TransparentButtonStyle}"
                            x:Name="ButtonForgotPassword"
                            Click="ButtonForgotPassword_Click"
                            TabIndex="4">
                            <TextBlock
                                x:Uid="LoginPage_TextBlockForgotPassword"
                                Text="Forgot Password"
                                FontSize="14"/>
                        </Button>

                    </StackPanel>



                </StackPanel>


                <Button
                    Grid.Row="1"
                    x:Uid="WelcomePage_ButtonLogIn"
                    x:Name="buttonLogin"
                    Content="LOG IN"
                    Style="{StaticResource WelcomeButtonStyle}"
                    Click="buttonLogin_Click"
                    Margin="20,0,20,20"
                    TabIndex="2"/>
            </Grid>
        </ScrollViewer>
    </views:PopupViewHostGeneric.MainContent>

</views:PopupViewHostGeneric>