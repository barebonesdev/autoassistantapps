<UserControl
    x:Class="AutoAssistantUWP.Views.GarageVehicleView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AutoAssistantUWP.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignHeight="300"
    d:DesignWidth="400"
    xmlns:converters="using:AutoAssistantUWP.Converters">

    <UserControl.Resources>
        <converters:MaintenanceStatusTypeToBackgroundConverter x:Key="MaintenanceStatusTypeToBackgroundConverter"/>
        <converters:MaintenanceStatusTypeToForegroundConverter x:Key="MaintenanceStatusTypeToForegroundConverter"/>
    </UserControl.Resources>

    <Grid
        Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
        MinHeight="150"
        Width="200"
        Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock
            Text="{Binding Nickname, FallbackValue=[nickname]}"
            Style="{ThemeResource SubtitleTextBlockStyle}"
            HorizontalAlignment="Center"
            Margin="6"
            VerticalAlignment="Center"/>

        <Border
            Background="{Binding MaintenanceStatusType, Converter={ThemeResource MaintenanceStatusTypeToBackgroundConverter}, FallbackValue={ThemeResource AppBarBackground}}"
            VerticalAlignment="Top"
            HorizontalAlignment="RIght"
            Padding="6,4"
            CornerRadius="6"
            Margin="6">
            <TextBlock
                Text="{Binding MaintenanceStatusText, FallbackValue=[maintenanceStatus]}"
                Style="{ThemeResource CaptionTextBlockStyle}"
                Foreground="{Binding MaintenanceStatusType, Converter={ThemeResource MaintenanceStatusTypeToForegroundConverter}, FallbackValue={ThemeResource ApplicationForegroundThemeBrush}}"/>
        </Border>

        <Border
            Grid.Row="1"
            Background="{ThemeResource AppBarBackground}"
            Padding="6">
            <TextBlock
                Text="{Binding YearMakeModelString, FallbackValue=[year/make/model]}"
                MaxLines="2"
                TextWrapping="Wrap"
                Style="{ThemeResource BodyTextBlockStyle}"/>
        </Border>
    </Grid>
</UserControl>
